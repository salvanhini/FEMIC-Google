rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(data) { return isSignedIn() && data.userId == request.auth.uid; }

    // --- Entity Validations ---
    function isValidPatient(data) {
      return data.keys().hasAll(['name', 'whatsapp', 'userId', 'created_at']) &&
             data.keys().size() >= 4 && data.keys().size() <= 10 &&
             data.name is string && data.name.size() <= 200 &&
             data.whatsapp is string && data.whatsapp.size() <= 30 &&
             data.userId == request.auth.uid;
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['patient_id', 'appointment_date', 'start_time', 'status', 'userId']) &&
             data.patient_id is string &&
             data.appointment_date is string &&
             data.status in ['agendado', 'confirmado', 'concluido', 'cancelado'] &&
             data.userId == request.auth.uid;
    }

    function isValidService(data) {
      return data.keys().hasAll(['name', 'price', 'userId']) &&
             data.name is string && data.name.size() <= 100 &&
             data.price is number &&
             data.userId == request.auth.uid;
    }

    function isValidPayer(data) {
      return data.keys().hasAll(['name', 'userId']) &&
             data.name is string && data.name.size() <= 100 &&
             data.userId == request.auth.uid;
    }

    function isValidPackage(data) {
      return data.keys().hasAll(['patient_id', 'service_id', 'total_sessions', 'userId']) &&
             data.patient_id is string &&
             data.service_id is string &&
             data.total_sessions is number &&
             data.userId == request.auth.uid;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['userId']) &&
             data.userId == request.auth.uid;
    }

    function isValidAnamnese(data) {
      return data.keys().hasAll(['patient_id', 'userId']) &&
             data.patient_id is string &&
             data.userId == request.auth.uid;
    }

    function isValidEvolution(data) {
      return data.keys().hasAll(['patient_id', 'userId']) &&
             data.patient_id is string &&
             data.userId == request.auth.uid;
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['patient_id', 'drive_url', 'userId']) &&
             data.patient_id is string &&
             data.drive_url is string &&
             data.userId == request.auth.uid;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && 
                       incoming().role == 'physio'; // Default role
      allow update: if isSignedIn() && request.auth.uid == userId &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    match /patients/{patientId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(patientId) && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidId(patientId) && isValidPatient(incoming());
      allow update: if isVerified() && isValidId(patientId) && isOwner(existing()) && isValidPatient(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'pathology', 'whatsapp', 'archived']);
      allow delete: if isVerified() && isOwner(existing());
    }

    match /appointments/{appointmentId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(appointmentId) && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidId(appointmentId) && isValidAppointment(incoming());
      allow update: if isVerified() && isValidId(appointmentId) && isOwner(existing()) && isValidAppointment(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['status', 'notes', 'appointment_date', 'start_time', 'end_time', 'package_consumed', 'session_package_id']);
      allow delete: if isVerified() && isOwner(existing());
    }

    match /services/{serviceId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(serviceId) && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidId(serviceId) && isValidService(incoming());
      allow update: if isVerified() && isValidId(serviceId) && isOwner(existing()) && isValidService(incoming());
      allow delete: if isVerified() && isOwner(existing());
    }

    match /payers/{payerId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(payerId) && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidId(payerId) && isValidPayer(incoming());
      allow update: if isVerified() && isValidId(payerId) && isOwner(existing()) && isValidPayer(incoming());
      allow delete: if isVerified() && isOwner(existing());
    }

    match /packages/{packageId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(packageId) && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidId(packageId) && isValidPackage(incoming());
      allow update: if isVerified() && isValidId(packageId) && isOwner(existing()) && isValidPackage(incoming());
      allow delete: if isVerified() && isOwner(existing());
    }

    match /settings/{settingId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(settingId) && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidId(settingId) && isValidSettings(incoming());
      allow update: if isVerified() && isValidId(settingId) && isOwner(existing()) && isValidSettings(incoming());
    }

    match /anamneses/{anamneseId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(anamneseId) && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidId(anamneseId) && isValidAnamnese(incoming());
      allow update: if isVerified() && isValidId(anamneseId) && isOwner(existing()) && isValidAnamnese(incoming());
      allow delete: if isVerified() && isOwner(existing());
    }

    match /evolutions/{evolutionId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(evolutionId) && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidId(evolutionId) && isValidEvolution(incoming());
      allow update: if isVerified() && isValidId(evolutionId) && isOwner(existing()) && isValidEvolution(incoming());
      allow delete: if isVerified() && isOwner(existing());
    }

    match /documents/{documentId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(documentId) && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidId(documentId) && isValidDocument(incoming());
      allow update: if isVerified() && isValidId(documentId) && isOwner(existing()) && isValidDocument(incoming());
      allow delete: if isVerified() && isOwner(existing());
    }
  }
}
